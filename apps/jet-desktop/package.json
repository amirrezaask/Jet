{
  "name": "jet-desktop",
  "version": "0.0.1",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "node scripts/electron-dev.mjs",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "release": "vite build && electron-builder --mac --dir --config electron-builder.yml",
    "pack:mac": "pnpm release",
    "pack:win": "vite build && electron-builder --win --config electron-builder.yml",
    "pack:linux": "vite build && electron-builder --linux --config electron-builder.yml"
  },
  "dependencies": {
    "@ff-labs/fff-node": "^0.9.6",
    "node-pty": "^1.0.0",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@jet/app": "workspace:*",
    "@jet/node-host": "workspace:*",
    "@jet/shared": "workspace:*",
    "@jet/workspace": "workspace:*",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "@tailwindcss/vite": "^4.1.8",
    "@types/node": "^22.15.29",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.5.2",
    "electron": "^36.4.0",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
