{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gharargah",
  "version": "0.0.1",
  "identifier": "com.gharargah.desktop",
  "build": {
    "beforeDevCommand": "node scripts/dev-frontend.mjs",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "capabilities": [
        "default"
      ],
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: blob:; connect-src 'self' http://127.0.0.1:* ws://127.0.0.1:* http: https: ws: wss:; worker-src 'self' blob:; object-src 'none'; base-uri 'self'"
    },
    "windows": [
      {
        "label": "main",
        "title": "Gharargah",
        "width": 1400,
        "height": 900,
        "decorations": true
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
