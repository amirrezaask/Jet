{
  "name": "gharargah",
  "private": true,
  "scripts": {
    "build": "node scripts/build-web-binary.mjs",
    "dev": "pnpm --filter gharargah dev",
    "test:server": "cargo test --manifest-path apps/server/Cargo.toml",
    "clean:rust": "cargo clean --manifest-path apps/server/Cargo.toml",
    "test:e2e": "playwright test --project=web-e2e",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "pnpm --filter @gharargah/workspace test && pnpm --filter @gharargah/lsp test && pnpm --filter @gharargah/node-host test && pnpm --filter @gharargah/host-client test && pnpm --filter @gharargah/app test",
    "test:bench": "playwright test --project=bench",
    "extract:vscode-keybindings": "node scripts/extract-vscode-mac-keybindings.mjs && node scripts/generate-default-keybindings.mjs",
    "validate:keybindings": "node scripts/validate-gharargah-keybindings.mjs",
    "release": "pnpm build"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@wdio/cli": "^9.12.0",
    "@wdio/local-runner": "^9.12.0",
    "@wdio/mocha-framework": "^9.12.0",
    "@wdio/spec-reporter": "^9.12.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "expect-webdriverio": "^5.1.0",
    "tsx": "^4.23.0",
    "turbo": "^2.10.4",
    "typescript": "^7.0.2"
  },
  "packageManager": "pnpm@9.15.0"
}
