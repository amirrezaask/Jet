{
  "name": "jet",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=jet-desktop",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "pnpm --filter @jet/workspace test && pnpm --filter @jet/lsp test && pnpm --filter @jet/node-host test && pnpm --filter @jet/app test",
    "test:electron": "pnpm --filter @jet/node-host build && pnpm --filter jet-desktop build && playwright test --project=electron",
    "extract:vscode-keybindings": "node scripts/extract-vscode-mac-keybindings.mjs && node scripts/generate-default-keybindings.mjs",
    "validate:keybindings": "node scripts/validate-jet-keybindings.mjs",
    "release": "pnpm --filter jet-desktop release && cp -r ./apps/jet-desktop/release/mac-arm64/Jet.app ~/Applications/",
    "postinstall": "pnpm rebuild electron && node scripts/fix-node-pty-perms.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "tsx": "^4.19.4",
    "turbo": "^2.5.4",
    "typescript": "^7.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
