{
  "name": "jet",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "pnpm --filter jet-tauri dev",
    "dev:tauri": "pnpm --filter jet-tauri dev",
    "test:tauri": "playwright test --project=tauri && PLAYWRIGHT_WORKERS=1 playwright test --project=tauri-e2e",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "pnpm --filter @jet/workspace test && pnpm --filter @jet/lsp test && pnpm --filter @jet/node-host test && pnpm --filter @jet/app test",
    "test:electron": "echo 'Electron shell removed; use pnpm test:tauri (tauri-e2e runs tests/electron specs)' && exit 1",
    "test:bench": "JET_SHELL=tauri playwright test --project=bench",
    "bench:startup:tauri": "pnpm --filter jet-tauri bench:startup:debug && pnpm --filter jet-tauri bench:startup:release",
    "extract:vscode-keybindings": "node scripts/extract-vscode-mac-keybindings.mjs && node scripts/generate-default-keybindings.mjs",
    "validate:keybindings": "node scripts/validate-jet-keybindings.mjs",
    "release": "pnpm --filter jet-tauri release && cp -r ./apps/jet-tauri/src-tauri/target/release/bundle/macos/Jet-Tauri.app ~/Applications/",
    "release:tauri": "pnpm --filter jet-tauri release && cp -r ./apps/jet-tauri/src-tauri/target/release/bundle/macos/Jet-Tauri.app ~/Applications/"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@wdio/cli": "^9.12.0",
    "@wdio/local-runner": "^9.12.0",
    "@wdio/mocha-framework": "^9.12.0",
    "@wdio/spec-reporter": "^9.12.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "expect-webdriverio": "^5.1.0",
    "tsx": "^4.23.0",
    "turbo": "^2.10.4",
    "typescript": "^7.0.2"
  },
  "packageManager": "pnpm@9.15.0"
}
