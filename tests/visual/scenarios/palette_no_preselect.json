{
  "window": { "width": 1280, "height": 800 },
  "workspace": "fixtures/sample-workspace",
  "files": ["src/index.ts"],
  "steps": [
    { "wait": { "ms": 300, "animations_idle": true } },
    { "command": "ui.showCommandPalette" },
    { "wait": { "ms": 300, "animations_idle": true } },
    { "assert_a11y_contains": ["Command palette", "Show Command Palette"] },
    { "assert_a11y_not_contains": ["[selected]"] },
    { "assert_layout": {
        "selector": "[role=\"option\"], [data-jet-list-item]",
        "min_items": 5,
        "min_row_height": 20
    }},
    { "text": "explorer" },
    { "wait": { "ms": 200 } },
    { "assert_a11y_contains": ["Show Explorer"] },
    { "assert_a11y_not_contains": ["No results", "No commands"] },
    { "key": "Enter" },
    { "wait": { "ms": 500, "animations_idle": true } },
    { "assert_a11y_contains": ["Explorer", "textbox"] },
    { "assert_state": { "paletteOpen": false } },
    { "assert_layout": { "min_items": 3, "min_row_height": 18 } },
    { "screenshot": "test-results/agent-shots/palette_no_preselect.png" },
    { "exit": 0 }
  ]
}
