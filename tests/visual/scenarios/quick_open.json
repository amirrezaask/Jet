{
  "window": { "width": 1280, "height": 800 },
  "workspace": "fixtures/sample-workspace",
  "files": ["src/index.ts"],
  "steps": [
    { "wait": { "ms": 3000, "animations_idle": true } },
    { "command": "workspace.quickOpen" },
    { "wait": { "ms": 500, "animations_idle": true } },
    { "a11y_snapshot": "test-results/agent-shots/quick_open.a11y.yaml" },
    { "text": "util" },
    { "wait": { "ms": 500 } },
    { "assert_a11y_contains": ["utils.ts"] },
    { "assert_a11y_not_contains": ["No results"] },
    { "assert_layout": {
        "selector": "[data-jet-list-item], [role=\"option\"]",
        "min_items": 1,
        "min_row_height": 20
    }},
    { "a11y_snapshot": "test-results/agent-shots/quick_open_util.a11y.yaml" },
    { "screenshot": "test-results/agent-shots/quick_open_util.png" },
    { "key": "Escape" },
    { "exit": 0 }
  ]
}
