{
  "window": { "width": 1280, "height": 800 },
  "workspace": "fixtures/sample-workspace",
  "files": ["src/example.rs"],
  "steps": [
    { "wait": { "ms": 500, "animations_idle": true } },
    {
      "assert_syntax_highlighting": {
        "selector": ".cm-line span",
        "min_colored_spans": 8,
        "min_unique_colors": 3,
        "require_keyword_color": true
      }
    },
    { "open_file": "src/index.ts" },
    { "wait": { "ms": 400, "animations_idle": true } },
    {
      "assert_syntax_highlighting": {
        "selector": ".cm-line span",
        "min_colored_spans": 8,
        "min_unique_colors": 3,
        "require_keyword_color": true
      }
    },
    { "exit": 0 }
  ]
}
