{
  "window": { "width": 1280, "height": 800 },
  "workspace": "fixtures/sample-workspace",
  "files": ["src/index.ts"],
  "steps": [
    { "wait": { "ms": 400, "animations_idle": true } },
    { "assert_a11y_contains": ["textbox"] },
    { "command": "explorer.show" },
    { "wait": { "ms": 500, "animations_idle": true } },
    { "a11y_snapshot": "test-results/agent-shots/explorer_with_editor.a11y.yaml" },
    { "assert_a11y_contains": ["Explorer", "textbox"] },
    { "assert_a11y_contains": ["index.ts"], "selector": "[data-jet-list-panel=\"explorer\"]" },
    { "assert_layout": { "min_items": 3, "min_unique_tops": 3, "min_row_height": 18 } },
    { "assert_row_text_visible": { "selector": "[data-jet-list-item]", "min_items": 3 } },
    { "assert_element_width": { "selector": ".cm-editor", "min_pct_of_viewport": 40 } },
    { "assert_state": { "paletteOpen": false } },
    { "screenshot": "test-results/agent-shots/explorer_with_editor.png" },
    { "key": "Meta+Shift+E" },
    { "wait": { "ms": 300 } },
    { "exit": 0 }
  ]
}
