{
  "window": { "width": 1280, "height": 800 },
  "workspace": "fixtures/sample-workspace",
  "files": ["src/index.ts"],
  "steps": [
    { "wait": { "ms": 300, "animations_idle": true } },
    { "command": "ui.showCommandPalette" },
    { "wait": { "ms": 300, "animations_idle": true } },
    { "a11y_snapshot": "test-results/agent-shots/command_palette.a11y.yaml" },
    { "assert_a11y_contains": ["Command palette", "Show Command Palette", "Quick Open File"] },
    { "assert_a11y_not_contains": ["Buffer List\" [selected]", "[selected]"] },
    { "assert_layout": {
        "selector": "[role=\"option\"], [data-jet-list-item]",
        "min_items": 5,
        "min_unique_tops": 5,
        "min_row_height": 20
    }},
    { "assert_row_text_visible": {
        "selector": "[role=\"option\"], [data-jet-list-item]",
        "min_items": 5
    }},
    { "assert_state": { "paletteOpen": true } },
    { "screenshot": "test-results/agent-shots/command_palette.png" },
    { "text": "explorer" },
    { "wait": { "ms": 200 } },
    { "assert_a11y_contains": ["Show Explorer"] },
    { "assert_a11y_not_contains": ["No commands", "No results"] },
    { "key": "Escape" },
    { "wait": { "ms": 200 } },
    { "assert_state": { "paletteOpen": false } },
    { "a11y_snapshot": "test-results/agent-shots/command_palette_closed.a11y.yaml" },
    { "exit": 0 }
  ]
}
