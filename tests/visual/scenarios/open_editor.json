{
  "window": { "width": 1280, "height": 800 },
  "workspace": "fixtures/sample-workspace",
  "files": ["src/index.ts"],
  "steps": [
    { "wait": { "ms": 500, "animations_idle": true } },
    { "a11y_snapshot": "test-results/agent-shots/open_editor.a11y.yaml" },
    { "assert_a11y_contains": ["export", "function"], "selector": ".cm-editor" },
    { "assert_element_width": { "selector": ".cm-editor", "min_pct_of_viewport": 50 } },
    { "assert_syntax_highlighting": {
        "selector": ".cm-line span",
        "min_colored_spans": 5,
        "min_unique_colors": 2
    }},
    { "screenshot": "test-results/agent-shots/open_editor.png" },
    { "exit": 0 }
  ]
}
