{
  "name": "@jet/host",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./sidecar": {
      "types": "./src/sidecar.ts",
      "import": "./dist/sidecar.js",
      "default": "./dist/sidecar.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "pnpm --filter @jet/shared build && pnpm --filter @jet/agents build && pnpm --filter @jet/node-host build && tsc -p tsconfig.json",
    "sidecar": "node dist/sidecar.js"
  },
  "dependencies": {
    "@ff-labs/fff-node": "^0.9.6",
    "@jet/agents": "workspace:*",
    "@jet/node-host": "workspace:*",
    "@jet/shared": "workspace:*",
    "@jet/workspace": "workspace:*",
    "node-pty": "^1.0.0",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/ws": "^8.18.1",
    "electron": "^36.4.0",
    "typescript": "^7.0.2"
  }
}
